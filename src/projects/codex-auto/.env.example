# Codex API Pool 环境变量配置

# 数据库配置
DATABASE_URL="file:./dev.db"

# 服务配置
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info

# 管理员密钥（用于管理后台登录）
ADMIN_KEY=your-secure-admin-key-here

# CORS配置
CORS_ORIGIN=http://localhost:5173

# Codex API配置
CODEX_API_BASE=https://api.openai.com/v1
